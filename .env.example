# ===== NLWeb Environment Variables =====
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# Optional variables can be left as-is if you don't use that service

# --- Logging ---
NLWEB_LOGGING_PROFILE=development    # production | development | testing

# --- Error Tracking (Sentry) ---
# SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=development       # production | development | testing

# --- LLM Providers (at least one required) ---

# [REQUIRED] OpenAI - primary LLM provider
OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Anthropic Claude (optional)
# NLWEB_ANTHROPIC_API_KEY=your_key_here

# Azure OpenAI (optional)
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_key_here

# --- Analytics Database ---
# Leave empty for SQLite (local dev default)
# For production PostgreSQL:
# ANALYTICS_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- External APIs (optional) ---

# Google Custom Search (for web search feature)
# GOOGLE_SEARCH_API_KEY=your_key_here
# GOOGLE_SEARCH_ENGINE_ID=your_engine_id_here

# HuggingFace (for embedding models)
# HF_TOKEN=hf_your_token_here

# --- Azure AI Search (optional, alternative vector backend) ---
# AZURE_VECTOR_SEARCH_ENDPOINT=https://YOUR_RESOURCE.search.windows.net
# AZURE_VECTOR_SEARCH_API_KEY=your_key_here

# --- Postgres (optional, for pgvector retrieval) ---
# POSTGRES_CONNECTION_STRING=postgresql://host:5432/db?user=user&sslmode=require
# POSTGRES_PASSWORD=your_password_here
