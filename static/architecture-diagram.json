    {
      "id": "context-map",
      "labelEn": "Context Map (Master B)",
      "labelZh": "上下文地圖",
      "moduleId": 7,
      "status": "planned",
      "rationale": "Major Upgrade — Association Layer 的核心產出物。\n研究的 B→A→B'→A' iterative loop 中的 B 端：Context Map 驅動 Search Plan，Search 結果 refine Context Map。\nMaster B 是整個研究過程的 living document，追蹤已知、未知、正在驗證中的概念。",
      "script": "",
      "x": 810,
      "y": 660,
      "workflows": ["workflow6"],
      "isModuleHeader": false,
      "style": "planned-major-upgrade"
    },
    {
      "id": "consistency-monitor",
      "labelEn": "Consistency Monitor",
      "labelZh": "一致性監控器",
      "moduleId": 4,
      "status": "planned",
      "rationale": "Major Upgrade — Critic Agent 的擴充。\n監控 long-horizon 研究過程中的邏輯一致性：偵測前後矛盾、論述漂移、未解決的衝突。\n當偵測到不一致時，發送轉折訊息給 Chat Agent，由讀豹 Voice 向使用者透明溝通。",
      "script": "",
      "x": 2494,
      "y": 940,
      "workflows": ["workflow6"],
      "isModuleHeader": false,
      "style": "planned-major-upgrade"
    },
    {
      "id": "propose-verify",
      "labelEn": "Propose-Verify",
      "labelZh": "提議-驗證機制",
      "moduleId": 7,
      "status": "planned",
      "rationale": "Major Upgrade — Association Layer 內部的品質控制機制。\n兩階段：(1) Propose 發散聯想候選 (2) Verify 以證據和邏輯篩選。\n確保聯想不是天馬行空，而是有根據的跨領域連結。",
      "script": "",
      "x": 1400,
      "y": 660,
      "workflows": ["workflow6"],
      "isModuleHeader": false,
      "style": "planned-major-upgrade"
    },
    {
      "id": "nonblocking-research",
      "labelEn": "Non-Blocking Research",
      "labelZh": "非阻塞研究模式",
      "moduleId": 4,
      "status": "planned",
      "rationale": "Major Upgrade — Deep Research Orchestrator 的新特性。\n允許研究過程不阻塞使用者互動：使用者可在研究進行中提出新問題、調整方向、或瀏覽中間結果。\n研究成為 living entity，可重啟、可延伸、可隨時介入。",
      "script": "",
      "x": 2494,
      "y": 420,
      "workflows": ["workflow6"],
      "isModuleHeader": false,
      "style": "planned-major-upgrade"
    }
